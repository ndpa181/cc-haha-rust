#!/usr/bin/env bash
# Launch claude-haha with ~/.claude/settings.kimi.json as the settings source
# --settings flag has the highest priority in the settings merge chain,
# so its env vars will override all other settings.json sources
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SETTINGS_FILE="$HOME/.claude/settings.kimi.json"

if [[ ! -f "$SETTINGS_FILE" ]]; then
  echo "Error: $SETTINGS_FILE not found" >&2
  exit 1
fi

export CALLER_DIR="$(pwd -W 2>/dev/null || pwd)"

cd "$ROOT_DIR"

if [[ "${CLAUDE_CODE_FORCE_RECOVERY_CLI:-0}" == "1" ]]; then
  exec bun --env-file=.env ./src/localRecoveryCli.ts --settings "$SETTINGS_FILE" "$@"
fi

exec bun --env-file=.env ./src/entrypoints/cli.tsx --settings "$SETTINGS_FILE" "$@"